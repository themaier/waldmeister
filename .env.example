# App
PUBLIC_APP_NAME=Waldmeister
ORIGIN=http://localhost:3000

# Database (Postgres + PostGIS)
# For local dev (app outside Docker, DB in Docker via docker-compose.dev.yml):
DATABASE_URL=postgres://waldmeister:waldmeister@localhost:5432/waldmeister
# For production docker-compose.yml this is overridden automatically to
# `postgres://waldmeister:waldmeister@db:5432/waldmeister` via the service env.

# Better-auth
# Generate a real secret for production: `openssl rand -base64 32`
BETTER_AUTH_SECRET=dev-only-secret-change-before-deploying-to-prod
BETTER_AUTH_URL=http://localhost:3000

# S3-compatible object storage (Cloudflare R2, MinIO, AWS S3…)
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=waldmeister
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# BayernAtlas
# Satellite base map (WMS). Read client-side by MapLibre — must be CORS-enabled
# and prefixed with VITE_ so Vite exposes it to the browser. Leave unset to use
# the public LDBV open-data endpoint (https://geoservices.bayern.de/od/wms/dop/v1/dop40).
VITE_BAYERN_WMS_SATELLITE=
# Flurstück WFS (server-side, used by $lib/server/bayernatlas.ts).
# Default URL points at the LDBV "ALKIS-vereinfacht" WFS, which **requires**
# HTTP Basic auth — LDBV only issues credentials to contract customers (see
# https://geodatenonline.bayern.de/geodatenonline/seiten/wfs_alkis).
# Override the URL/typeName for an INSPIRE beta or another mirror.
BAYERN_WFS_FLURSTUECK=
BAYERN_WFS_FLURSTUECK_TYPENAME=
BAYERN_WFS_USER=
BAYERN_WFS_PASS=

# SMTP (work-order completion mails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Waldmeister <no-reply@example.com>"

# Caddy (deployment)
DOMAIN=waldmeister.example.com
ACME_EMAIL=admin@example.com
